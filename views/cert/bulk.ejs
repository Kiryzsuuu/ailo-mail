<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Bulk Generate Sertifikat — AILO</title>
  <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
  <link rel="stylesheet" href="/print.css" />
  <style>
    .upload-zone {
      border: 2px dashed var(--line);
      border-radius: 10px;
      padding: 40px 24px;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      background: #fafafa;
    }
    .upload-zone.dragover { border-color: var(--primary); background: #f0f4ff; }
    .upload-zone input[type="file"] { display: none; }
    .col-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .col-table th { background: var(--bg); text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--line); font-weight: 700; }
    .col-table td { padding: 8px 10px; border-bottom: 1px solid var(--line); vertical-align: top; }
    .badge-req { background: #e8f5e9; color: #2e7d32; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 700; }
    .badge-opt { background: #f3f3f3; color: #666; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }
    .progress-bar { width: 100%; height: 6px; background: var(--line); border-radius: 99px; overflow: hidden; display: none; }
    .progress-bar-inner { height: 100%; background: var(--primary); border-radius: 99px; transition: width 0.2s; }
    .loading-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.35); z-index: 999;
      display: none; align-items: center; justify-content: center;
      flex-direction: column; gap: 16px; color: #fff;
    }
    .spinner {
      width: 44px; height: 44px;
      border: 4px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
<div class="shell">
  <%- include('../partials/nav', { currentUser, active: 'cert' }) %>

  <main class="page">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px; flex-wrap:wrap">
      <a class="btn ghost" href="/cert" style="padding:0 12px">&larr;</a>
      <div>
        <h1 class="app-title" style="margin:0">Bulk Generate Sertifikat</h1>
        <p class="muted" style="margin:4px 0 0">Template: <strong><%= template.name %></strong></p>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 360px; gap:24px; align-items:start">

      <!-- Upload form -->
      <div class="paper" style="padding:24px">
        <h2 style="margin:0 0 16px; font-size:16px">Upload File Excel</h2>

        <form method="POST" action="/cert/<%= template._id %>/bulk" enctype="multipart/form-data" id="bulkForm">
          <div class="upload-zone" id="dropZone" onclick="document.getElementById('excelInput').click()">
            <input type="file" name="excelFile" id="excelInput" accept=".xlsx,.xls,.csv" required />
            <div style="font-size:36px; margin-bottom:8px">📊</div>
            <div style="font-weight:700; margin-bottom:4px">Klik atau drag & drop file Excel</div>
            <div class="muted small">Format: .xlsx, .xls · Maks. 10 MB</div>
            <div id="fileName" class="muted small" style="margin-top:8px; font-style:italic"></div>
          </div>

          <div class="progress-bar" id="progressBar" style="margin-top:12px">
            <div class="progress-bar-inner" id="progressInner" style="width:0%"></div>
          </div>

          <div style="margin-top:20px; display:flex; gap:8px">
            <button type="submit" class="btn" style="flex:1" id="submitBtn">Generate & Download ZIP</button>
            <a class="btn ghost" href="/cert/<%= template._id %>/generate" style="padding:0 14px; display:flex; align-items:center">Satuan</a>
          </div>
        </form>
      </div>

      <!-- Column guide -->
      <div class="paper" style="padding:20px">
        <h2 style="margin:0 0 14px; font-size:15px">Panduan Kolom Excel</h2>
        <p class="muted small" style="margin:0 0 12px">Buat baris pertama sebagai header dengan nama kolom persis seperti di bawah. Kolom yang digunakan template ini ditandai <span class="badge-req">Dipakai</span>.</p>

        <%
          const usedFields = new Set((template.elements || []).filter(e => e.type === 'field').map(e => e.field));
        %>
        <table class="col-table">
          <thead>
            <tr>
              <th>Nama Kolom</th>
              <th>Keterangan</th>
            </tr>
          </thead>
          <tbody>
            <% Object.keys(FIELD_LABELS).forEach(function(key) { %>
              <tr>
                <td><code style="font-size:12px; background:#f5f5f5; padding:2px 5px; border-radius:3px"><%= key %></code></td>
                <td>
                  <%= fieldLabel(key) %>
                  <% if (usedFields.has(key)) { %>
                    <span class="badge-req">Dipakai</span>
                  <% } else { %>
                    <span class="badge-opt">Opsional</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>

        <div style="margin-top:16px; padding:12px; background:#fffde7; border-radius:6px; border:1px solid #ffe082">
          <p class="small" style="margin:0; font-weight:700; margin-bottom:6px">Contoh baris Excel:</p>
          <table style="font-size:11px; border-collapse:collapse; width:100%">
            <tr style="background:#fff8e1">
              <% Object.keys(FIELD_LABELS).forEach(function(k) { %>
                <th style="padding:3px 6px; border:1px solid #ffe082; text-align:left; white-space:nowrap"><%= k %></th>
              <% }); %>
            </tr>
            <tr>
              <td style="padding:3px 6px; border:1px solid #ffe082">Budi Santoso</td>
              <td style="padding:3px 6px; border:1px solid #ffe082">15 Januari 2025</td>
              <td style="padding:3px 6px; border:1px solid #ffe082">001/CERT/2025</td>
              <td style="padding:3px 6px; border:1px solid #ffe082">Workshop AI</td>
              <td style="padding:3px 6px; border:1px solid #ffe082">Peserta</td>
              <td style="padding:3px 6px; border:1px solid #ffe082">Universitas Telkom</td>
            </tr>
          </table>
        </div>

        <div style="margin-top:12px">
          <a href="data:text/csv;charset=utf-8,<%= encodeURIComponent(Object.keys(FIELD_LABELS).join(',') + '\nBudi Santoso,15 Januari 2025,001/CERT/2025,Workshop AI,Peserta,Universitas Telkom') %>"
             download="template_sertifikat.csv"
             class="btn ghost small"
             style="font-size:12px; padding:6px 12px">
            Download Template CSV
          </a>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Loading overlay -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="spinner"></div>
  <div style="font-size:16px; font-weight:700">Generating sertifikat...</div>
  <div class="muted" style="color:rgba(255,255,255,0.8); font-size:13px" id="loadingMsg">Mohon tunggu, sedang memproses</div>
</div>

<script>
(function () {
  var dropZone = document.getElementById('dropZone');
  var input = document.getElementById('excelInput');
  var fileNameEl = document.getElementById('fileName');
  var form = document.getElementById('bulkForm');
  var overlay = document.getElementById('loadingOverlay');
  var loadingMsg = document.getElementById('loadingMsg');

  input.addEventListener('change', function () {
    if (input.files[0]) fileNameEl.textContent = input.files[0].name;
  });

  dropZone.addEventListener('dragover', function (e) {
    e.preventDefault();
    dropZone.classList.add('dragover');
  });
  dropZone.addEventListener('dragleave', function () {
    dropZone.classList.remove('dragover');
  });
  dropZone.addEventListener('drop', function (e) {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    var files = e.dataTransfer.files;
    if (files[0]) {
      input.files = files; // may not work on all browsers — fallback below
      fileNameEl.textContent = files[0].name;
    }
  });

  form.addEventListener('submit', function () {
    overlay.style.display = 'flex';
    var count = 0;
    var msgs = ['Memuat file Excel...', 'Membangun sertifikat...', 'Membuat PDF...', 'Mengemas ZIP...'];
    var interval = setInterval(function () {
      count++;
      if (count < msgs.length) loadingMsg.textContent = msgs[count];
    }, 3000);
    // Hide overlay when download starts (approximate via visibilitychange)
    setTimeout(function () {
      clearInterval(interval);
      overlay.style.display = 'none';
    }, 60000);
  });
})();
</script>
</body>
</html>
