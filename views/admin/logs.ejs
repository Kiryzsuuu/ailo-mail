<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Activity Logs - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell">
      <header class="nav">
        <a class="brand" href="/dashboard">
          <img class="brand-logo" src="/assets/logo-ailo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Activity Logs</div>
            <div class="brand-subtitle"><%= currentUser.email %> • <%= currentUser.role %></div>
          </div>
        </a>
        <div class="nav-actions">
          <a class="btn ghost" href="/dashboard">Dashboard</a>
          <a class="btn ghost" href="/admin/users">Users</a>
        </div>
      </header>

      <main class="page">
        <h1 class="app-title">ACTIVITY LOGS</h1>
        <p class="muted">Semua aktivitas user (USER sampai SUPERADMIN).</p>

        <div class="paper">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:12px; flex-wrap:wrap">
            <div class="muted">Menampilkan <strong><%= logs.length %></strong> log terbaru.</div>
            <div style="display:flex; gap:8px; align-items:center">
              <% if (page > 1) { %>
                <a class="btn ghost" href="/admin/logs?page=<%= page - 1 %>">Prev</a>
              <% } %>
              <span class="muted">Page <strong><%= page %></strong></span>
              <% if (hasNext) { %>
                <a class="btn ghost" href="/admin/logs?page=<%= page + 1 %>">Next</a>
              <% } %>
            </div>
          </div>

          <div style="overflow:auto">
            <table style="width:100%; min-width:980px; border-collapse:collapse">
              <thead>
                <tr>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Waktu</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Actor</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Role</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Action</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Route</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Status</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Meta</th>
                </tr>
              </thead>
              <tbody>
                <% logs.forEach(function (l) { %>
                  <tr>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line); white-space:nowrap">
                      <%= new Date(l.createdAt).toLocaleString('id-ID') %>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)">
                      <div style="font-weight:700"><%= (l.actor && (l.actor.name || l.actor.email)) ? (l.actor.name || l.actor.email) : '-' %></div>
                      <div class="muted" style="font-size:12px"><%= (l.actor && l.actor.email) ? l.actor.email : '' %></div>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)"><%= (l.actor && l.actor.role) ? l.actor.role : '-' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)"><code><%= l.action %></code></td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)">
                      <div><code><%= l.method %></code> <code><%= l.path %></code></div>
                    </td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)"><%= (l.statusCode !== null && l.statusCode !== undefined) ? l.statusCode : '-' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)">
                      <div class="muted" style="font-size:12px; max-width:380px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis">
                        <%= (l.meta && Object.keys(l.meta).length) ? JSON.stringify(l.meta) : '' %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
