<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tambah User - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell">
      <header class="nav">
        <a class="brand" href="/admin/users">
          <img class="brand-logo" src="/logo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Tambah User</div>
            <div class="brand-subtitle"><%= currentUser.email %> • <%= currentUser.role %></div>
          </div>
        </a>
        <div class="nav-actions">
          <a class="btn ghost" href="/admin/users">Kembali</a>
        </div>
      </header>

      <main class="page">
        <h1 class="app-title">TAMBAH USER</h1>
        <% if (error) { %>
          <p class="muted"><strong><%= error %></strong></p>
        <% } %>

        <form action="/admin/users" method="post">
          <div class="grid">
            <label class="span-2">
              Email
              <input name="email" type="email" required />
            </label>
            <label class="span-2">
              Nama
              <input name="name" />
            </label>
            <label>
              Role
              <select name="role">
                <% roles.forEach(function (r) { %>
                  <option value="<%= r %>"><%= r %></option>
                <% }) %>
              </select>
            </label>
            <label>
              Password
              <input name="password" type="password" required />
            </label>
          </div>
          <div class="actions">
            <button class="btn" type="submit">Buat User</button>
          </div>
        </form>
      </main>
    </div>
  </body>
</html>
