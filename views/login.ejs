<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
    <link rel="stylesheet" href="/auth.css" />
  </head>
  <body class="auth">
    <div class="auth-shell">
      <aside class="auth-aside">
        <a class="auth-brand" href="/">
          <img src="/assets/logo-ailo.png" alt="AILO" />
          <strong>Web Mailer</strong>
        </a>

        <div class="auth-hero">
          <h1>
            AILO<br />
            <span>WEB<br />MAILER</span>
          </h1>
          <p>Login ke akun Anda untuk mengakses Web Mailer.</p>
        </div>

        <div></div>
      </aside>

      <main class="auth-panel">
        <div class="auth-card">
          <h1 class="auth-title">SIGN IN</h1>
          <p class="auth-subtitle">Masuk dengan email dan password Anda.</p>

          <% if (error) { %>
            <div class="auth-alert" role="alert"><%= error %></div>
          <% } %>

          <form class="auth-form" action="/login" method="post">
            <div class="auth-field">
              <label for="email">Email address</label>
              <input id="email" name="email" type="email" autocomplete="username" placeholder="yourname@gmail.com" required />
            </div>
            <div class="auth-field">
              <label for="password">Password</label>
              <input id="password" name="password" type="password" autocomplete="current-password" placeholder="••••••••" required />
            </div>

            <div class="auth-actions">
              <button class="auth-btn" type="submit">Sign in</button>
            </div>
          </form>

          <div class="auth-links">
            <div><a href="/forgot-password">Lupa password?</a></div>
            <div>Belum punya akun? <a href="/register">Register</a></div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
