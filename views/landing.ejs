<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell">
      <header class="nav">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Web Mailer</div>
          </div>
        </a>

        <nav class="nav-links" aria-label="Navigasi">
          <a href="/mailer">Mailer</a>
          <a href="https://ailo.telkomuniversity.ac.id/#research" target="_blank" rel="noreferrer">Research</a>
          <a href="https://ailo.telkomuniversity.ac.id/#projects" target="_blank" rel="noreferrer">Projects</a>
          <a href="https://ailo.telkomuniversity.ac.id/#team" target="_blank" rel="noreferrer">Team</a>
          <a href="https://ailo.telkomuniversity.ac.id/#about" target="_blank" rel="noreferrer">About</a>
        </nav>

      </header>

      <main class="hero">
        <div class="hero-grid">
          <section>
            <div class="hero-eyebrow">AI Laboratory and Operations</div>
            <h1 class="hero-title">AI Laboratory<br/><span class="hero-teal">and Operations</span></h1>
            <p class="hero-desc">
              <span class="hero-accent">Kolaborasi untuk Inovasi</span>
            </p>

            <div class="hero-actions">
              <a class="btn" href="/mailer">Buat Surat</a>
              <a class="btn ghost" href="https://ailo.telkomuniversity.ac.id/" target="_blank" rel="noreferrer">Collaborate With Us</a>
            </div>

          </section>

          <aside class="mosaic" aria-label="Ilustrasi">
            <div class="tile big">
              <img class="tile-img" src="/hero-tile-1.jpg" alt="" />
            </div>
            <div class="tile light">
              <img class="tile-img" src="/hero-tile-2.jpg" alt="" />
            </div>
            <div class="tile light">
              <img class="tile-img" src="/hero-tile-3.jpg" alt="" />
            </div>
          </aside>
        </div>
      </main>

      <footer class="footer">
        <span class="muted">© <%= new Date().getFullYear() %> AILO web mailer</span>
      </footer>
    </div>
  </body>
</html>
