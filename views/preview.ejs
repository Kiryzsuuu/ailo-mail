<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
    <style>
      /* Keep regular .paper cards unchanged; only the letter preview should be A4 and non-rounded */
      .paper { position: relative; }

      .paper.letter-preview {
        padding: 0;
        border-radius: 0;
        border: none;
        box-shadow: none;
        background: transparent;
        overflow: visible;
      }

      .paper.letter-preview .letter {
        width: 210mm;
        height: 297mm;
        margin: 0 auto;
      }

      /* Ensure barcode/QR previews are not rounded */
      .paper.letter-preview .barcode {
        border-radius: 0 !important;
      }

      .drag-barcode {
        position: absolute;
        width: var(--size, 96px);
        height: var(--size, 96px);
        left: var(--x, 80%);
        top: var(--y, 86%);
        transform: translate(-50%, -50%);
        touch-action: none;
        cursor: grab;
        user-select: none;
      }
      .drag-barcode.hidden { display: none; }
      .drag-barcode:active { cursor: grabbing; }
      .drag-barcode img {
        width: var(--size, 96px);
        height: var(--size, 96px);
        object-fit: contain;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0;
        background: #fff;
      }
      .status-pill {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-weight: 800;
        font-size: 12px;
      }

      body.adjust-barcode .letter .barcode {
        touch-action: none;
        cursor: grab;
        user-select: none;
      }
      body.adjust-barcode .letter .barcode:active { cursor: grabbing; }
    </style>
  </head>
  <body
    class="<%= canAdjustBarcode ? 'adjust-barcode' : '' %>"
    data-current-user-id="<%= String(currentUser._id) %>"
    data-is-superadmin="<%= String(currentUser.role || '').toUpperCase() === 'SUPERADMIN' ? '1' : '0' %>"
  >
    <div class="shell">
      <header class="nav">
        <a class="brand" href="/dashboard">
          <img class="brand-logo" src="/logo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Web Mailer</div>
        <div class="paper letter-preview">
          </div>
        </a>

        <nav class="nav-links" aria-label="Navigasi">
          <a href="/mailer">Mailer</a>
          <a href="https://ailo.telkomuniversity.ac.id/#research" target="_blank" rel="noreferrer">Research</a>
          <a href="https://ailo.telkomuniversity.ac.id/#projects" target="_blank" rel="noreferrer">Projects</a>
          <a href="https://ailo.telkomuniversity.ac.id/#team" target="_blank" rel="noreferrer">Team</a>
          <a href="https://ailo.telkomuniversity.ac.id/#about" target="_blank" rel="noreferrer">About</a>
        </nav>

        <div class="nav-actions">
          <a class="btn ghost" href="/mailer">Buat Surat Baru</a>
          <a class="btn ghost" href="/dashboard">Dashboard</a>
          <form class="inline" action="/logout" method="post">
            <button class="btn" type="submit">Logout</button>
          </form>
        </div>
      </header>

      <main class="page">
        <% if (err) { %>
          <div class="paper" style="border:1px solid rgba(180,0,0,0.25); background:rgba(255,0,0,0.04); margin-bottom:12px">
            <strong>Perhatian:</strong> <%= err %>
          </div>
        <% } %>

        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:12px">
          <div>
            <div class="muted">Status</div>
            <div class="status-pill"><%= letter.status %></div>
          </div>

          <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap">
            <% if (canSubmit) { %>
              <form class="inline" action="/letters/<%= letter._id %>/submit" method="post">
                <button class="btn" type="submit">Submit ke Supreme</button>
              </form>
            <% } %>

            <% if (canMarkSent) { %>
              <form class="inline" action="/letters/<%= letter._id %>/mark-sent" method="post">
                <button class="btn ghost" type="submit">Tandai Terkirim</button>
              </form>
            <% } %>

            <% if (canDownload) { %>
              <a class="btn" href="/letters/<%= letter._id %>/pdf">Download PDF</a>
            <% } %>
          </div>
        </div>

        <% const isCreator = String(letter.createdBy) === String(currentUser._id); %>
        <% if (isCreator && (letter.status === 'DRAFT' || letter.status === 'SUBMITTED')) { %>
          <div class="paper" style="margin-bottom:14px">
            <h3 style="margin:0 0 8px">Tanda Tangan Supreme</h3>
            <p class="muted" style="margin:0 0 12px">
              Pilih Supreme yang wajib menandatangani (bisa 1, 2, atau 3). Waktu submit, surat akan muncul di halaman Approval Supreme yang dipilih.
            </p>

            <form action="/letters/<%= letter._id %>/request-signers" method="post" style="display:grid; gap:10px">
              <div style="display:grid; gap:8px">
                <% if (!supremeUsers || !supremeUsers.length) { %>
                  <div class="muted">Belum ada user role SUPREME.</div>
                <% } else { %>
                  <% supremeUsers.forEach(function(u) { %>
                    <% const checked = (letter.requestedSigners || []).some(function(r) { return String(r.userId) === String(u._id); }); %>
                    <label style="display:flex; align-items:center; gap:10px; font-weight:600">
                      <input type="checkbox" name="signerIds" value="<%= u._id %>" <%= checked ? 'checked' : '' %> />
                      <span><%= u.email %> <span class="muted small">(Tier <%= u.supremeTier || 1 %>)</span></span>
                    </label>
                  <% }) %>
                <% } %>
              </div>

              <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end">
                <button class="btn ghost" type="submit">Simpan Penandatangan</button>
              </div>
            </form>
          </div>
        <% } %>

        <% if (canApprove && showApprovePanel) { %>
          <div class="paper" style="margin-bottom:14px">
            <h3 style="margin:0 0 8px"><%= letter.status === 'APPROVED' ? 'Tambah Tanda Tangan (Barcode)' : 'Approve + Tanda Tangan (Barcode)' %></h3>
            <p class="muted" style="margin:0 0 12px">Klik "Generate Barcode" untuk memunculkan barcode (pending), geser posisinya di preview surat (di bawah), atur ukuran jika perlu, lalu klik <%= letter.status === 'APPROVED' ? 'Tanda Tangan' : 'Approve' %>.</p>
            <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin:0 0 10px">
              <button class="btn ghost" type="button" id="btnGenerateBarcode">Generate Barcode</button>
              <label class="muted small" style="display:flex; align-items:center; gap:8px">
                Ukuran
                <input id="sizePt" name="sizePt" type="number" min="48" max="160" step="1" value="<%= Number(letter.barcodeSizePt || 92) %>" style="width:90px" />
                pt
              </label>
              <span class="muted small">(48–160 pt)</span>
            </div>
            <form action="/letters/<%= letter._id %>/approve" method="post" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap">
              <input type="hidden" name="xPct" id="xPct" value="<%= letter.barcodePosition?.xPct ?? 80 %>" />
              <input type="hidden" name="yPct" id="yPct" value="<%= letter.barcodePosition?.yPct ?? 86 %>" />
              <input type="hidden" name="sizePt" id="sizePtHidden" value="<%= Number(letter.barcodeSizePt || 92) %>" />
              <button class="btn" type="submit"><%= letter.status === 'APPROVED' ? 'Tanda Tangan' : 'Approve & Sign' %></button>
              <span class="muted small">(Posisi tersimpan otomatis dari drag)</span>
            </form>
          </div>
        <% } %>

        <% if (canAdjustBarcode) { %>
          <div class="paper" style="margin-bottom:14px">
            <h3 style="margin:0 0 8px">Atur Posisi Barcode</h3>
            <p class="muted" style="margin:0">Klik dan geser barcode di surat untuk mengubah posisinya. Posisi akan tersimpan otomatis.</p>
          </div>
        <% } %>

        <div class="paper">
          <%- html %>

          <% if (canApprove && showApprovePanel) { %>
            <div class="drag-barcode hidden" id="dragBarcode" style="--x:<%= (letter.barcodePosition?.xPct ?? 80) %>%; --y:<%= (letter.barcodePosition?.yPct ?? 86) %>%; --size:<%= Number(letter.barcodeSizePt || 92) %>pt">
              <img src="<%= barcodePreviewDataUrl %>" alt="Barcode" />
            </div>
          <% } %>
        </div>
      </main>
    </div>

    <% if (canApprove && showApprovePanel) { %>
      <script>
        (function () {
          var el = document.getElementById('dragBarcode');
          if (!el) return;

          var btn = document.getElementById('btnGenerateBarcode');
          var sizeInput = document.getElementById('sizePt');
          var sizeHidden = document.getElementById('sizePtHidden');

          var xInput = document.getElementById('xPct');
          var yInput = document.getElementById('yPct');

          var paper = el.closest('.paper');
          if (!paper) return;
          var letterEl = paper.querySelector('.letter') || paper;

          var dragging = false;

          function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }

          function syncSize() {
            if (!sizeInput) return;
            var n = Number(sizeInput.value);
            if (!isFinite(n)) n = 92;
            n = clamp(n, 48, 160);
            sizeInput.value = String(Math.round(n));
            el.style.setProperty('--size', n + 'pt');
            if (sizeHidden) sizeHidden.value = String(Math.round(n));
          }

          if (sizeInput) {
            sizeInput.addEventListener('change', syncSize);
            sizeInput.addEventListener('input', syncSize);
          }

          function setPosFromClient(clientX, clientY) {
            var rect = letterEl.getBoundingClientRect();
            var x = ((clientX - rect.left) / rect.width) * 100;
            var y = ((clientY - rect.top) / rect.height) * 100;
            x = clamp(x, 0, 100);
            y = clamp(y, 0, 100);
            el.style.setProperty('--x', x + '%');
            el.style.setProperty('--y', y + '%');
            if (xInput) xInput.value = String(Math.round(x * 100) / 100);
            if (yInput) yInput.value = String(Math.round(y * 100) / 100);
          }

          el.addEventListener('pointerdown', function (ev) {
            dragging = true;
            try { el.setPointerCapture(ev.pointerId); } catch (e) {}
            setPosFromClient(ev.clientX, ev.clientY);
            ev.preventDefault();
          });

          el.addEventListener('pointermove', function (ev) {
            if (!dragging) return;
            setPosFromClient(ev.clientX, ev.clientY);
            ev.preventDefault();
          });

          el.addEventListener('pointerup', function (ev) {
            dragging = false;
            ev.preventDefault();
          });

          function ensureVisible() {
            if (el.classList.contains('hidden')) el.classList.remove('hidden');
          }

          async function generateBarcode() {
            syncSize();
            ensureVisible();
            try {
              var res = await fetch('/letters/<%= letter._id %>/barcode/pending');
              var json = await res.json();
              if (json && json.ok && json.dataUrl) {
                var img = el.querySelector('img');
                if (img) img.src = String(json.dataUrl);
              }
            } catch (e) {
              // ignore
            }
          }

          if (btn) {
            btn.addEventListener('click', function () {
              generateBarcode();
            });
          }

          // Keep size applied on load
          syncSize();
        })();
      </script>
    <% } %>

    <% if (canAdjustBarcode) { %>
      <script type="application/json" id="signatureMeta">
        <%- JSON.stringify((letter.signatures || []).map(function (s) {
          return { signatureId: String(s.signatureId || ''), signerId: String(s.signerId || '') };
        })) %>
      </script>
      <script>
        (function () {
          var paper = document.querySelector('.paper');
          if (!paper) return;

          var letterEl = paper.querySelector('.letter') || paper;
          var barcodes = Array.prototype.slice.call(paper.querySelectorAll('.letter .barcode'));
          if (!barcodes.length) return;

          var body = document.body;
          var currentUserId = String(body.getAttribute('data-current-user-id') || '');
          var isSuperAdmin = String(body.getAttribute('data-is-superadmin') || '') === '1';

          var sigMeta = [];
          try {
            var jsonEl = document.getElementById('signatureMeta');
            sigMeta = JSON.parse(jsonEl ? jsonEl.textContent : '[]') || [];
          } catch (e) {
            sigMeta = [];
          }

          function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }

          function canDragBarcode(el) {
            if (isSuperAdmin) return true;
            var signatureId = String(el.getAttribute('data-signature-id') || '');
            if (!signatureId) return false;

            var sig = sigMeta.find(function (s) {
              return s && String(s.signatureId || '') === signatureId;
            });
            if (!sig) return false;
            return String(sig.signerId || '') === String(currentUserId);
          }

          function attachDrag(barcode) {
            if (!canDragBarcode(barcode)) return;

            var signatureId = String(barcode.getAttribute('data-signature-id') || '');
            if (!signatureId) return;

            var dragging = false;
            var last = { xPct: null, yPct: null };
            var saveTimer = null;

            function scheduleSave(xPct, yPct) {
              last.xPct = xPct;
              last.yPct = yPct;
              if (saveTimer) window.clearTimeout(saveTimer);
              saveTimer = window.setTimeout(function () {
                fetch('/letters/<%= letter._id %>/barcode-position', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ signatureId: signatureId, xPct: last.xPct, yPct: last.yPct }),
                }).catch(function () { /* ignore */ });
              }, 250);
            }

            function setPosFromClient(clientX, clientY) {
              var rect = letterEl.getBoundingClientRect();
              var x = ((clientX - rect.left) / rect.width) * 100;
              var y = ((clientY - rect.top) / rect.height) * 100;
              x = clamp(x, 0, 100);
              y = clamp(y, 0, 100);
              barcode.style.left = x + '%';
              barcode.style.top = y + '%';
              scheduleSave(Math.round(x * 100) / 100, Math.round(y * 100) / 100);
            }

            barcode.addEventListener('pointerdown', function (ev) {
              dragging = true;
              try { barcode.setPointerCapture(ev.pointerId); } catch (e) {}
              setPosFromClient(ev.clientX, ev.clientY);
              ev.preventDefault();
            });

            barcode.addEventListener('pointermove', function (ev) {
              if (!dragging) return;
              setPosFromClient(ev.clientX, ev.clientY);
              ev.preventDefault();
            });

            barcode.addEventListener('pointerup', function (ev) {
              dragging = false;
              ev.preventDefault();
            });
          }

          for (var i = 0; i < barcodes.length; i++) {
            attachDrag(barcodes[i]);
          }
        })();
      </script>
    <% } %>
  </body>
</html>
