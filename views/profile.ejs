<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit Profile - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell shell--wide">
      <header class="nav nav--white">
        <a class="brand" href="/">
          <img class="brand-logo" src="/assets/logo-ailo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Web Mailer</div>
          </div>
        </a>

        <div class="nav-actions nav-actions--right">
          <% if (currentUser) { %>
            <div class="profile-dropdown">
              <button class="btn ghost" id="profileToggle" type="button">
                <span class="profile-avatar" aria-hidden="true">
                  <img src="/assets/avatar-placeholder.svg" alt="" />
                </span>
                <span><%= (currentUser.name && String(currentUser.name).trim()) ? currentUser.name : (currentUser.email ? String(currentUser.email).split('@')[0] : '') %></span>
              </button>
              <div class="dropdown-menu" id="dropdownMenu">
                <a href="/profile" class="dropdown-item">Edit Profile</a>
                <div class="dropdown-divider"></div>
                <button type="button" class="dropdown-item dropdown-logout" id="logoutTrigger">Logout</button>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Logout Confirmation Modal -->
        <div class="modal" id="logoutModal">
          <div class="modal-content">
            <div class="modal-header">
              <h2>Konfirmasi Logout</h2>
              <button type="button" class="modal-close" id="closeModal">×</button>
            </div>
            <div class="modal-body">
              <p>Apakah Anda yakin ingin logout? Anda akan perlu login kembali untuk mengakses akun Anda.</p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" id="cancelLogout">Batal</button>
              <button type="button" class="btn btn-primary" id="confirmLogout">Ya, Logout</button>
            </div>
          </div>
        </div>

        <script>
          // Profile dropdown toggle
          const profileToggle = document.getElementById('profileToggle');
          const dropdownMenu = document.getElementById('dropdownMenu');
          const logoutModal = document.getElementById('logoutModal');
          const logoutTrigger = document.getElementById('logoutTrigger');
          const closeModal = document.getElementById('closeModal');
          const cancelLogout = document.getElementById('cancelLogout');
          const confirmLogout = document.getElementById('confirmLogout');

          function positionDropdown() {
            if (!profileToggle || !dropdownMenu) return;
            const rect = profileToggle.getBoundingClientRect();

            // Ensure it's measurable
            dropdownMenu.style.display = 'block';
            dropdownMenu.style.visibility = 'hidden';
            dropdownMenu.style.position = 'fixed';

            const menuWidth = dropdownMenu.offsetWidth || 220;
            const gutter = 12;

            const top = Math.round(rect.bottom + 6);
            const left = Math.round(Math.min(rect.right - menuWidth, window.innerWidth - menuWidth - gutter));
            const safeLeft = Math.max(gutter, left);

            dropdownMenu.style.top = `${top}px`;
            dropdownMenu.style.left = `${safeLeft}px`;
            dropdownMenu.style.right = 'auto';

            dropdownMenu.style.visibility = '';
            dropdownMenu.style.display = '';
          }

          function openDropdown() {
            if (!dropdownMenu) return;
            dropdownMenu.classList.add('active');
            positionDropdown();
          }

          function closeDropdown() {
            if (!dropdownMenu) return;
            dropdownMenu.classList.remove('active');
          }

          if (profileToggle) {
            profileToggle.addEventListener('click', () => {
              const willOpen = !dropdownMenu.classList.contains('active');
              if (willOpen) openDropdown();
              else closeDropdown();
            });

            document.addEventListener('click', (e) => {
              if (!e.target.closest('.profile-dropdown')) {
                closeDropdown();
              }
            });

            document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape') closeDropdown();
            });

            window.addEventListener('resize', () => {
              if (dropdownMenu.classList.contains('active')) positionDropdown();
            });

            window.addEventListener('scroll', () => {
              if (dropdownMenu.classList.contains('active')) positionDropdown();
            }, { passive: true });
          }

          // Logout confirmation modal
          if (logoutTrigger) {
            logoutTrigger.addEventListener('click', () => {
              logoutModal.classList.add('active');
            });
          }

          if (closeModal || cancelLogout) {
            const closeHandler = () => {
              logoutModal.classList.remove('active');
            };
            if (closeModal) closeModal.addEventListener('click', closeHandler);
            if (cancelLogout) cancelLogout.addEventListener('click', closeHandler);
          }

          if (confirmLogout) {
            confirmLogout.addEventListener('click', () => {
              confirmLogout.disabled = true;
              confirmLogout.textContent = 'Logging out...';
              // Submit logout form via fetch
              fetch('/logout', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                credentials: 'include'
              })
              .then(res => {
                console.log('[CLIENT] Logout response:', res.status);
                if (res.redirected) {
                  window.location.href = res.url;
                } else {
                  window.location.href = '/login';
                }
              })
              .catch(err => {
                console.error('[CLIENT] Logout error:', err);
                confirmLogout.disabled = false;
                confirmLogout.textContent = 'Ya, Logout';
                alert('Logout gagal. Silakan coba lagi.');
              });
            });
          }
        </script>
      </header>

      <main class="hero">
        <div class="hero-container hero-container--profile">
          <section class="profile-page">
            <div class="hero-eyebrow">Akun Saya</div>
            <h1 class="hero-title">My <span class="hero-teal">Profile</span></h1>
            <p class="hero-desc">Kelola data pribadi dan keamanan akun Anda.</p>

            <div class="profile-card profile-card--full">
              <div class="profile-head">
                <div class="profile-card__avatar" aria-hidden="true">
                  <img src="/assets/avatar-placeholder.svg" alt="" />
                </div>
                <div class="profile-card__meta">
                  <div class="profile-card__name"><%= currentUser.name || 'Pengguna' %></div>
                  <div class="profile-card__email"><%= currentUser.email %></div>
                  <div class="profile-card__role"><%= String(currentUser.role || 'USER') %></div>
                </div>
              </div>

              <% if (errors && errors.length > 0) { %>
                <div class="alert alert-error">
                  <strong>Periksa kembali:</strong>
                  <ul>
                    <% errors.forEach(err => { %>
                      <li><%= err %></li>
                    <% }); %>
                  </ul>
                </div>
              <% } %>

              <% if (success) { %>
                <div class="alert alert-success">Profil berhasil diperbarui.</div>
              <% } %>

              <div class="profile-sections">
                <section class="profile-section">
                  <h2>Data Pribadi</h2>
                  <p class="panel-desc">Update nama yang tampil di aplikasi.</p>
                  <form action="/profile" method="post" class="panel-form">
                    <div class="form-row">
                      <div class="form-group">
                        <label for="name">Nama Lengkap</label>
                        <input type="text" id="name" name="name" value="<%= currentUser.name || '' %>" placeholder="Masukkan nama Anda" required />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label>Email</label>
                        <input type="email" value="<%= currentUser.email %>" disabled />
                        <small>Email dapat diubah lewat menu Reset Email.</small>
                      </div>
                    </div>
                    <div class="panel-actions">
                      <button type="submit" class="btn btn-primary">Simpan Data</button>
                    </div>
                  </form>
                </section>

                <section class="profile-section">
                  <h2>Reset Email</h2>
                  <p class="panel-desc">Ubah email akun dengan verifikasi OTP ke email baru.</p>
                  <form action="/profile/request-email-change" method="post" class="panel-form">
                    <div class="form-row">
                      <div class="form-group">
                        <label for="newEmail">Email Baru</label>
                        <input type="email" id="newEmail" name="newEmail" placeholder="emailbaru@example.com" required />
                      </div>
                      <div class="form-group">
                        <label for="emailPassword">Password Saat Ini</label>
                        <input type="password" id="emailPassword" name="currentPassword" placeholder="Password saat ini" required />
                      </div>
                    </div>
                    <div class="panel-actions">
                      <button type="submit" class="btn btn-primary">Kirim OTP</button>
                    </div>
                  </form>
                </section>

                <section class="profile-section">
                  <h2>Reset Password</h2>
                  <p class="panel-desc">Ganti password dengan memasukkan password saat ini.</p>
                  <form action="/profile/password" method="post" class="panel-form">
                    <div class="form-row">
                      <div class="form-group">
                        <label for="currentPassword">Password Saat Ini</label>
                        <input type="password" id="currentPassword" name="currentPassword" placeholder="Password saat ini" required />
                      </div>
                      <div class="form-group">
                        <label for="newPassword">Password Baru</label>
                        <input type="password" id="newPassword" name="newPassword" placeholder="Minimal 8 karakter" required />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label for="confirmPassword">Konfirmasi Password Baru</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Ulangi password baru" required />
                      </div>
                    </div>
                    <div class="panel-actions">
                      <button type="submit" class="btn btn-primary">Update Password</button>
                    </div>
                  </form>
                </section>
              </div>

              <div class="profile-bottom">
                <a class="btn btn-success profile-back" href="/">Kembali</a>
              </div>
            </div>
          </section>
        </div>
      </main>

      <footer class="footer">
        <span class="muted">© <%= new Date().getFullYear() %> AILO web mailer</span>
      </footer>
    </div>
  </body>
</html>
