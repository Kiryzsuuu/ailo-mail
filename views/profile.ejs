<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit Profile — AILO</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
    <style>
      body {
        background-image: none;
        background-color: #f4f6f9;
      }

      .profile-header {
        padding: 28px 0 20px;
      }
      .profile-header .eyebrow {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        margin: 0 0 6px;
      }
      .profile-header h1 {
        margin: 0 0 4px;
        font-size: 28px;
        font-weight: 800;
      }
      .profile-header p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
      }

      /* User info card */
      .user-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 12px;
      }
      .user-avatar {
        width: 56px;
        height: 56px;
        border-radius: 999px;
        overflow: hidden;
        border: 2px solid rgba(11,122,141,0.2);
        background: rgba(11,122,141,0.06);
        flex-shrink: 0;
      }
      .user-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .user-info .name  { font-weight: 800; font-size: 16px; margin: 0 0 2px; }
      .user-info .email { color: var(--muted); font-size: 13px; margin: 0 0 6px; }
      .role-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        background: rgba(11,122,141,0.1);
        color: var(--primary);
      }

      /* Section cards — same pattern as generator */
      .form-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid var(--line);
        overflow: hidden;
        margin-bottom: 12px;
      }
      .form-section { padding: 22px 24px; }

      .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
      }
      .section-num {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        background: var(--primary);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .section-title {
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.8px;
      }
      .section-desc {
        font-size: 13px;
        color: var(--muted);
        margin: -12px 0 16px 36px;
      }

      /* Fields */
      .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px 20px;
      }
      .field-grid .full { grid-column: 1 / -1; }
      @media (max-width: 600px) {
        .field-grid { grid-template-columns: 1fr; }
        .field-grid .full { grid-column: 1; }
        .form-section { padding: 18px 16px; }
        .user-card { padding: 16px; }
      }

      .f-label {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .f-label span {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .f-label input {
        border-radius: 10px;
        border: 1px solid var(--line);
        padding: 9px 12px;
        font-size: 14px;
        background: #fff;
        transition: border-color 0.15s;
        width: 100%;
      }
      .f-label input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(11,122,141,0.08);
      }
      .f-label input:disabled {
        background: #f5f5f5;
        color: var(--muted);
        cursor: not-allowed;
      }
      .f-label .hint {
        font-size: 11px;
        color: var(--muted);
        margin: 0;
        font-weight: 400;
        text-transform: none;
        letter-spacing: 0;
      }

      /* Action row */
      .action-row {
        display: flex;
        justify-content: flex-end;
        margin-top: 18px;
      }
      .action-row .btn { padding: 10px 28px; font-size: 14px; font-weight: 700; border-radius: 10px; }

      /* Alert */
      .alert {
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 16px;
      }
      .alert-error   { background: rgba(220,38,38,0.06); border: 1px solid rgba(220,38,38,0.2); color: #b91c1c; }
      .alert-success { background: rgba(22,163,74,0.06); border: 1px solid rgba(22,163,74,0.2); color: #15803d; }
      .alert ul { margin: 4px 0 0 16px; padding: 0; }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('./partials/nav', { currentUser, active: 'profile' }) %>

      <main class="page">
        <div class="profile-header">
          <p class="eyebrow">Akun Saya</p>
          <h1>My <span style="color:var(--primary)">Profile</span></h1>
          <p>Kelola data pribadi dan keamanan akun Anda.</p>
        </div>

        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-error">
            <strong>Periksa kembali:</strong>
            <ul><% errors.forEach(e => { %><li><%= e %></li><% }); %></ul>
          </div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success">Profil berhasil diperbarui.</div>
        <% } %>

        <!-- User info -->
        <div class="user-card">
          <div class="user-avatar">
            <img src="/assets/avatar-placeholder.svg" alt="" />
          </div>
          <div class="user-info">
            <p class="name"><%= currentUser.name || 'Pengguna' %></p>
            <p class="email"><%= currentUser.email %></p>
            <span class="role-badge"><%= String(currentUser.role || 'USER') %></span>
          </div>
        </div>

        <!-- 1. Data Pribadi -->
        <div class="form-card">
          <div class="form-section">
            <div class="section-header">
              <div class="section-num">1</div>
              <div class="section-title">Data Pribadi</div>
            </div>
            <p class="section-desc">Update nama yang tampil di aplikasi.</p>
            <form action="/profile" method="post">
              <div class="field-grid">
                <div class="f-label">
                  <span>Nama Lengkap</span>
                  <input type="text" name="name" value="<%= currentUser.name || '' %>" placeholder="Masukkan nama Anda" required />
                </div>
                <div class="f-label">
                  <span>Email</span>
                  <input type="email" value="<%= currentUser.email %>" disabled />
                  <span class="hint">Email dapat diubah lewat menu Reset Email.</span>
                </div>
              </div>
              <div class="action-row">
                <button type="submit" class="btn">Simpan Data</button>
              </div>
            </form>
          </div>
        </div>

        <!-- 2. Reset Email -->
        <div class="form-card">
          <div class="form-section">
            <div class="section-header">
              <div class="section-num">2</div>
              <div class="section-title">Reset Email</div>
            </div>
            <p class="section-desc">Ubah email akun dengan verifikasi OTP ke email baru.</p>
            <form action="/profile/request-email-change" method="post">
              <div class="field-grid">
                <div class="f-label">
                  <span>Email Baru</span>
                  <input type="email" name="newEmail" placeholder="emailbaru@example.com" required />
                </div>
                <div class="f-label">
                  <span>Password Saat Ini</span>
                  <input type="password" name="currentPassword" placeholder="Password saat ini" required />
                </div>
              </div>
              <div class="action-row">
                <button type="submit" class="btn">Kirim OTP</button>
              </div>
            </form>
          </div>
        </div>

        <!-- 3. Reset Password -->
        <div class="form-card">
          <div class="form-section">
            <div class="section-header">
              <div class="section-num">3</div>
              <div class="section-title">Reset Password</div>
            </div>
            <p class="section-desc">Ganti password dengan memasukkan password saat ini.</p>
            <form action="/profile/password" method="post">
              <div class="field-grid">
                <div class="f-label">
                  <span>Password Saat Ini</span>
                  <input type="password" name="currentPassword" placeholder="Password saat ini" required />
                </div>
                <div class="f-label">
                  <span>Password Baru</span>
                  <input type="password" name="newPassword" placeholder="Minimal 8 karakter" required />
                </div>
                <div class="f-label">
                  <span>Konfirmasi Password Baru</span>
                  <input type="password" name="confirmPassword" placeholder="Ulangi password baru" required />
                </div>
              </div>
              <div class="action-row">
                <button type="submit" class="btn">Update Password</button>
              </div>
            </form>
          </div>
        </div>

        <div style="margin-bottom:32px">
          <a class="btn ghost" href="/dashboard">&larr; Kembali ke Dashboard</a>
        </div>
      </main>

      <footer class="footer">
        <span class="muted">© <%= new Date().getFullYear() %> AILO web mailer</span>
      </footer>
    </div>
  </body>
</html>
