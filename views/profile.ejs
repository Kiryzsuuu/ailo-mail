<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit Profile - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell shell--wide">
      <%- include('./partials/nav', { currentUser, active: 'profile' }) %>

      <main class="hero">
        <div class="hero-container hero-container--profile">
          <section class="profile-page">
            <div class="hero-eyebrow">Akun Saya</div>
            <h1 class="hero-title">My <span class="hero-teal">Profile</span></h1>
            <p class="hero-desc">Kelola data pribadi dan keamanan akun Anda.</p>

            <div class="profile-card profile-card--full">
              <div class="profile-head">
                <div class="profile-card__avatar" aria-hidden="true">
                  <img src="/assets/avatar-placeholder.svg" alt="" />
                </div>
                <div class="profile-card__meta">
                  <div class="profile-card__name"><%= currentUser.name || 'Pengguna' %></div>
                  <div class="profile-card__email"><%= currentUser.email %></div>
                  <div class="profile-card__role"><%= String(currentUser.role || 'USER') %></div>
                </div>
              </div>

              <% if (errors && errors.length > 0) { %>
                <div class="alert alert-error">
                  <strong>Periksa kembali:</strong>
                  <ul>
                    <% errors.forEach(err => { %>
                      <li><%= err %></li>
                    <% }); %>
                  </ul>
                </div>
              <% } %>

              <% if (success) { %>
                <div class="alert alert-success">Profil berhasil diperbarui.</div>
              <% } %>

              <div class="profile-sections">
                <section class="profile-section">
                  <h2>Data Pribadi</h2>
                  <p class="panel-desc">Update nama yang tampil di aplikasi.</p>
                  <form action="/profile" method="post" class="panel-form">
                    <div class="form-row">
                      <div class="form-group">
                        <label for="name">Nama Lengkap</label>
                        <input type="text" id="name" name="name" value="<%= currentUser.name || '' %>" placeholder="Masukkan nama Anda" required />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label>Email</label>
                        <input type="email" value="<%= currentUser.email %>" disabled />
                        <small>Email dapat diubah lewat menu Reset Email.</small>
                      </div>
                    </div>
                    <div class="panel-actions">
                      <button type="submit" class="btn btn-primary">Simpan Data</button>
                    </div>
                  </form>
                </section>

                <section class="profile-section">
                  <h2>Reset Email</h2>
                  <p class="panel-desc">Ubah email akun dengan verifikasi OTP ke email baru.</p>
                  <form action="/profile/request-email-change" method="post" class="panel-form">
                    <div class="form-row">
                      <div class="form-group">
                        <label for="newEmail">Email Baru</label>
                        <input type="email" id="newEmail" name="newEmail" placeholder="emailbaru@example.com" required />
                      </div>
                      <div class="form-group">
                        <label for="emailPassword">Password Saat Ini</label>
                        <input type="password" id="emailPassword" name="currentPassword" placeholder="Password saat ini" required />
                      </div>
                    </div>
                    <div class="panel-actions">
                      <button type="submit" class="btn btn-primary">Kirim OTP</button>
                    </div>
                  </form>
                </section>

                <section class="profile-section">
                  <h2>Reset Password</h2>
                  <p class="panel-desc">Ganti password dengan memasukkan password saat ini.</p>
                  <form action="/profile/password" method="post" class="panel-form">
                    <div class="form-row">
                      <div class="form-group">
                        <label for="currentPassword">Password Saat Ini</label>
                        <input type="password" id="currentPassword" name="currentPassword" placeholder="Password saat ini" required />
                      </div>
                      <div class="form-group">
                        <label for="newPassword">Password Baru</label>
                        <input type="password" id="newPassword" name="newPassword" placeholder="Minimal 8 karakter" required />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label for="confirmPassword">Konfirmasi Password Baru</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Ulangi password baru" required />
                      </div>
                    </div>
                    <div class="panel-actions">
                      <button type="submit" class="btn btn-primary">Update Password</button>
                    </div>
                  </form>
                </section>
              </div>

              <div class="profile-bottom">
                <a class="btn btn-success profile-back" href="/">Kembali</a>
              </div>
            </div>
          </section>
        </div>
      </main>

      <footer class="footer">
        <span class="muted">© <%= new Date().getFullYear() %> AILO web mailer</span>
      </footer>
    </div>
  </body>
</html>
