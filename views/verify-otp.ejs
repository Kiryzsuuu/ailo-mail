<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verifikasi OTP - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
    <link rel="stylesheet" href="/auth.css" />
  </head>
  <body class="auth">
    <div class="auth-shell">
      <aside class="auth-aside">
        <a class="auth-brand" href="/">
          <img src="/assets/logo-ailo.png" alt="AILO" />
          <strong>Web Mailer</strong>
        </a>

        <div class="auth-hero">
          <h1>
            VERIFY<br />
            <span>YOUR OTP</span>
          </h1>
          <p>Masukkan kode OTP yang telah dikirim ke email Anda untuk melanjutkan.</p>
        </div>

        <div></div>
      </aside>

      <main class="auth-panel">
        <div class="auth-card">
          <h1 class="auth-title">VERIFIKASI OTP</h1>
          <p class="auth-subtitle">Kode OTP dikirim ke: <strong><%= email %></strong></p>

        <% if (error) { %>
          <div class="auth-alert" role="alert"><%= error %></div>
        <% } %>
        <% if (info) { %>
          <div class="auth-info" role="status"><%= info %></div>
        <% } %>

        <form class="auth-form" action="/verify-otp" method="post">
          <input type="hidden" name="email" value="<%= email %>" />
          <input type="hidden" name="purpose" value="<%= purpose %>" />
          
          <div class="auth-field">
            <label for="code">Kode OTP</label>
            <input id="code" name="code" type="text" autocomplete="one-time-code" placeholder="000000" required />
          </div>

          <div class="auth-actions">
            <button class="auth-btn" type="submit">Verifikasi</button>
          </div>
        </form>
        </div>
      </main>
    </div>
  </body>
</html>
