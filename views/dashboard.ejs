<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell">
      <header class="nav">
        <a class="brand" href="/">
          <img class="brand-logo" src="/assets/logo-ailo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Web Mailer</div>
            <div class="brand-subtitle"><%= currentUser.email %> • <%= currentUser.role %></div>
          </div>
        </a>

        <nav class="nav-links" aria-label="Navigasi">
          <a href="/mailer">Buat Surat</a>
          <% if (String(currentUser.role || '').toUpperCase() === 'USER') { %>
            <a href="/upload">Upload Dokumen</a>
          <% } %>
          <% if (canApprove) { %>
            <a href="/approvals">Approval</a>
          <% } %>
          <% if (canManageUsers) { %>
            <a href="/admin/users">Users</a>
            <a href="/admin/logs">Logs</a>
          <% } %>
        </nav>

        <div class="nav-actions">
          <form class="inline" action="/logout" method="post">
            <button class="btn ghost" type="submit">Logout</button>
          </form>
        </div>
      </header>

      <main class="page">
        <h1 class="app-title">DASHBOARD</h1>
        <p class="muted">Daftar surat yang bisa kamu akses.</p>

        <div class="paper">
          <% if (!letters.length) { %>
            <p class="muted">Belum ada surat.</p>
          <% } else { %>
            <table style="width:100%; border-collapse:collapse">
              <thead>
                <tr>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Nomor</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Perihal</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Status</th>
                  <th style="text-align:left; padding:10px 8px; border-bottom:1px solid var(--line)">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% letters.forEach(function (l) { %>
                  <tr>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)"><%= l.number || '-' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)"><%= l.subject || '-' %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)"><%= l.status %></td>
                    <td style="padding:10px 8px; border-bottom:1px solid var(--line)">
                      <a class="btn ghost" href="/letters/<%= l._id %>/preview" style="padding:8px 12px; border-radius:12px">Buka</a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>
