<% const headerSrc = (kop.headerImageDataUrl && String(kop.headerImageDataUrl).trim()) || (kop.headerImagePath && String(kop.headerImagePath).trim()) || ''; %>
<% if (headerSrc) { %>
  <div class="kop kop--image">
    <img class="kop-header" src="<%= headerSrc %>" alt="Kop Surat" />
  </div>
<% } else { %>
  <div class="kop kop--simple">
    <% const logoSrc = (kop.logoDataUrl && String(kop.logoDataUrl).trim()) || (kop.logoPath && String(kop.logoPath).trim()) || ''; %>
    <% if (logoSrc) { %>
      <img class="kop-logo" src="<%= logoSrc %>" alt="Logo" />
    <% } else { %>
      <div class="kop-logo-placeholder">LOGO</div>
    <% } %>
  </div>
<% } %>
