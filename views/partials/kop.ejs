<div class="kop kop--simple">
  <% const logoSrc = (kop.logoDataUrl && String(kop.logoDataUrl).trim()) || (kop.logoPath && String(kop.logoPath).trim()) || ''; %>
  <% if (logoSrc) { %>
    <img class="kop-logo" src="<%= logoSrc %>" alt="Logo" />
  <% } else { %>
    <div class="kop-logo-placeholder">LOGO</div>
  <% } %>
</div>
