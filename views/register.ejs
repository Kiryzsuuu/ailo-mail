<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
  </head>
  <body>
    <div class="shell">
      <header class="nav">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo.png" alt="AILO" />
          <div class="brand-text">
            <div class="brand-title">Web Mailer</div>
          </div>
        </a>

        <div class="nav-actions">
          <a class="btn ghost" href="/login">Login</a>
        </div>
      </header>

      <main class="page">
        <h1 class="app-title">REGISTER</h1>
        <% if (error) { %>
          <p class="muted"><strong><%= error %></strong></p>
        <% } %>

        <form action="/register" method="post">
          <div class="grid">
            <label class="span-2">
              Nama (opsional)
              <input name="name" />
            </label>
            <label class="span-2">
              Email
              <input name="email" type="email" autocomplete="username" required />
            </label>
            <label class="span-2">
              Password
              <input name="password" type="password" autocomplete="new-password" required />
            </label>
          </div>
          <div class="actions">
            <button class="btn" type="submit">Buat Akun</button>
          </div>
        </form>

        <p class="muted small" style="margin-top:12px">
          Akun yang dibuat lewat register otomatis menjadi role <strong>USER</strong>.
        </p>
      </main>
    </div>
  </body>
</html>
