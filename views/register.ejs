<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - AILO WEB MAILER</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
    <link rel="stylesheet" href="/auth.css" />
  </head>
  <body class="auth">
    <div class="auth-shell">
      <aside class="auth-aside">
        <a class="auth-brand" href="/">
          <img src="/assets/logo-ailo.png" alt="AILO" />
          <strong>Web Mailer</strong>
        </a>

        <div class="auth-hero">
          <h1>
            SIGN UP<br />
            <span>START YOUR<br />JOURNEY</span>
          </h1>
          <p>Buat akun baru untuk mulai menggunakan Web Mailer.</p>
        </div>

        <div></div>
      </aside>

      <main class="auth-panel">
        <div class="auth-card">
          <h1 class="auth-title">SIGN UP</h1>
          <p class="auth-subtitle">Daftar dengan email dan password (minimal 8 karakter).</p>

          <% if (error) { %>
            <div class="auth-alert" role="alert"><%= error %></div>
          <% } %>

          <form class="auth-form" action="/register" method="post">
            <div class="auth-field">
              <label for="name">Nama (opsional)</label>
              <input id="name" name="name" type="text" autocomplete="name" placeholder="Nama kamu" />
            </div>
            <div class="auth-field">
              <label for="email">Email address</label>
              <input id="email" name="email" type="email" autocomplete="username" placeholder="yourname@gmail.com" required />
            </div>
            <div class="auth-field">
              <label for="password">Password</label>
              <input id="password" name="password" type="password" autocomplete="new-password" placeholder="••••••••" required />
            </div>

            <div class="auth-actions">
              <button class="auth-btn" type="submit">Buat Akun</button>
            </div>
          </form>

          <div class="auth-links">
            <div>Sudah punya akun? <a href="/login">Login</a></div>
            <div>Akun yang dibuat lewat register otomatis menjadi <strong>USER</strong>.</div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
