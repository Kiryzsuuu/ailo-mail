<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Generator Surat — AILO</title>
    <link rel="icon" type="image/png" href="/assets/ailo-favicon.png" />
    <link rel="stylesheet" href="/print.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" />
    <style>
      /* Override dots background for this page only */
      body {
        background-image: none;
        background-color: #f4f6f9;
      }

      /* ── Page header ── */
      .gen-header {
        padding: 28px 0 20px;
      }
      .gen-header h1 {
        margin: 0 0 4px;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: 0.3px;
      }
      .gen-header p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
      }

      /* ── Form card ── */
      .form-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid var(--line);
        overflow: hidden;
        margin-bottom: 12px;
      }

      .form-section {
        padding: 22px 24px;
        border-bottom: 1px solid var(--line);
      }
      .form-section:last-child { border-bottom: none; }

      .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
      }
      .section-num {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        background: var(--primary);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .section-title {
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--text);
      }

      /* ── Field layout ── */
      .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px 20px;
      }
      .field-grid .full { grid-column: 1 / -1; }

      @media (max-width: 640px) {
        .field-grid { grid-template-columns: 1fr; }
        .field-grid .full { grid-column: 1; }
        .form-section { padding: 18px 16px; }
      }

      .f-label {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .f-label span {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .f-label input,
      .f-label select,
      .f-label textarea {
        border-radius: 10px;
        border: 1px solid var(--line);
        padding: 9px 12px;
        font-size: 14px;
        background: #fff;
        transition: border-color 0.15s;
        width: 100%;
      }
      .f-label input:focus,
      .f-label select:focus,
      .f-label textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(11,122,141,0.08);
      }
      .f-label textarea { resize: vertical; }

      /* ── Quill ── */
      .ql-toolbar.ql-snow {
        border: none;
        border-bottom: 1px solid var(--line);
        border-radius: 10px 10px 0 0;
        background: #fafafa;
        padding: 7px 10px;
        flex-wrap: wrap;
      }
      .ql-container.ql-snow {
        border: none;
        font-family: var(--uiFont, Calibri, "Segoe UI", Arial, sans-serif);
        font-size: 14px;
        line-height: 1.6;
      }
      .ql-editor { padding: 12px 14px; }
      .ql-editor.ql-blank::before {
        color: rgba(11,19,32,0.35);
        font-style: normal;
      }
      .quill-wrap {
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
        transition: border-color 0.15s;
      }
      .quill-wrap:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(11,122,141,0.08);
      }
      .quill-wrap--sm .ql-editor { min-height: 90px; }
      .quill-wrap--lg .ql-editor { min-height: 260px; }

      /* ── Table editor ── */
      .table-wrap {
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
      }
      .table-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        background: #fafafa;
        border-bottom: 1px solid var(--line);
      }
      .table-toolbar span { font-size: 13px; color: var(--muted); }
      #tableEditor { width: 100%; border-collapse: collapse; }
      #tableEditor th { padding: 8px 10px; text-align: left; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; color: var(--muted); background: #fafafa; border-bottom: 1px solid var(--line); }
      #tableEditor td { padding: 4px 8px; border-bottom: 1px solid var(--line); }
      #tableEditor tr:last-child td { border-bottom: none; }
      #tableEditor input { border-radius: 7px; padding: 6px 9px; font-size: 13px; }

      /* ── Submit bar ── */
      .submit-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 18px 24px;
        background: #fff;
        border-radius: 16px;
        border: 1px solid var(--line);
        margin-bottom: 32px;
      }
      .submit-bar .hint { font-size: 13px; color: var(--muted); }
      .submit-bar .btn {
        padding: 12px 32px;
        font-size: 15px;
        font-weight: 700;
        border-radius: 12px;
      }

      .hidden-field { display: none !important; }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('./partials/nav', { currentUser, active: 'mailer' }) %>

      <main class="page">
        <div class="gen-header">
          <h1>Generator Surat</h1>
          <p>Isi form di bawah, lalu klik <strong>Preview Surat</strong> untuk melihat dan mengunduh PDF.</p>
        </div>

        <form action="/letters/preview" method="post" id="letterForm">

          <!-- ① Jenis & Tampilan -->
          <div class="form-card">
            <div class="form-section">
              <div class="section-header">
                <div class="section-num">1</div>
                <div class="section-title">Jenis &amp; Tampilan</div>
              </div>
              <div class="field-grid">
                <div class="f-label full">
                  <span>Jenis Surat</span>
                  <select name="template" id="templateSelect">
                    <option value="DEFAULT"                       <%= (defaults.template||'DEFAULT')==='DEFAULT'                       ? 'selected':'' %>>Surat Umum (Default)</option>
                    <option value="SURAT_TUGAS"                   <%= defaults.template==='SURAT_TUGAS'                   ? 'selected':'' %>>Surat Tugas</option>
                    <option value="SURAT_TUGAS_PANDUAN"           <%= defaults.template==='SURAT_TUGAS_PANDUAN'           ? 'selected':'' %>>Surat Tugas Panduan</option>
                    <option value="SURAT_TUGAS_TENAGA_AHLI"       <%= defaults.template==='SURAT_TUGAS_TENAGA_AHLI'       ? 'selected':'' %>>Surat Tugas Tenaga Ahli</option>
                    <option value="SURAT_TUGAS_UNDANGAN"          <%= defaults.template==='SURAT_TUGAS_UNDANGAN'          ? 'selected':'' %>>Surat Tugas Undangan</option>
                    <option value="SURAT_TUGAS_IN_HOUSE_TRAINING" <%= defaults.template==='SURAT_TUGAS_IN_HOUSE_TRAINING' ? 'selected':'' %>>Surat Tugas In-House Training</option>
                  </select>
                </div>
                <div class="f-label">
                  <span>Font</span>
                  <select name="font" id="fontSelect">
                    <option value="calibri"   <%= (defaults.font||'calibri')==='calibri'   ? 'selected':'' %>>Calibri</option>
                    <option value="arial"     <%= defaults.font==='arial'     ? 'selected':'' %>>Arial</option>
                    <option value="times"     <%= defaults.font==='times'     ? 'selected':'' %>>Times New Roman</option>
                    <option value="georgia"   <%= defaults.font==='georgia'   ? 'selected':'' %>>Georgia</option>
                    <option value="tahoma"    <%= defaults.font==='tahoma'    ? 'selected':'' %>>Tahoma</option>
                    <option value="verdana"   <%= defaults.font==='verdana'   ? 'selected':'' %>>Verdana</option>
                    <option value="trebuchet" <%= defaults.font==='trebuchet' ? 'selected':'' %>>Trebuchet MS</option>
                    <option value="garamond"  <%= defaults.font==='garamond'  ? 'selected':'' %>>Garamond</option>
                    <option value="courier"   <%= defaults.font==='courier'   ? 'selected':'' %>>Courier New</option>
                    <option value="system"    <%= defaults.font==='system'    ? 'selected':'' %>>System UI</option>
                  </select>
                </div>
                <div class="f-label">
                  <span>Font Custom <span style="font-weight:400;text-transform:none;letter-spacing:0">(opsional)</span></span>
                  <input name="fontCustom" id="fontCustom" placeholder="Contoh: Cambria, serif" value="<%= defaults.fontCustom||'' %>" />
                </div>
                <div class="f-label">
                  <span>Ukuran Font (pt)</span>
                  <input type="number" name="fontSizePt" min="8" max="24" step="0.5" value="<%= defaults.fontSizePt||12 %>" />
                </div>
                <div class="f-label">
                  <span>Line Spacing</span>
                  <input type="number" name="lineHeight" min="1" max="2.2" step="0.05" value="<%= defaults.lineHeight||1.55 %>" />
                </div>
                <div class="f-label">
                  <span>Spasi Paragraf (pt)</span>
                  <input type="number" name="paragraphSpacingPt" min="0" max="24" step="1" value="<%= defaults.paragraphSpacingPt||0 %>" />
                </div>
                <div class="f-label">
                  <span>Spasi Antar Bagian (pt)</span>
                  <input type="number" name="sectionSpacingPt" min="0" max="48" step="1" value="<%= defaults.sectionSpacingPt||0 %>" />
                </div>
              </div>
            </div>
          </div>

          <!-- ② Detail Surat -->
          <div class="form-card">
            <div class="form-section">
              <div class="section-header">
                <div class="section-num">2</div>
                <div class="section-title">Detail Surat</div>
              </div>
              <div class="field-grid">
                <div class="f-label">
                  <span>Tempat</span>
                  <input name="place" value="<%= defaults.place %>" placeholder="Bandung" />
                </div>
                <div class="f-label">
                  <span>Tanggal</span>
                  <input type="date" name="date" value="<%= defaults.date %>" />
                </div>
                <div class="f-label">
                  <span>Nomor Surat</span>
                  <input name="number" placeholder="001/AILO/III/2026" value="<%= defaults.number %>" />
                </div>
                <div class="f-label">
                  <span>Lampiran</span>
                  <input name="attachment" value="<%= defaults.attachment||'-' %>" />
                </div>
                <div class="f-label full">
                  <span>Perihal</span>
                  <input name="subject" placeholder="Contoh: Permohonan Data Penelitian" value="<%= defaults.subject %>" />
                </div>
              </div>
            </div>
          </div>

          <!-- ③ Penerima -->
          <div class="form-card">
            <div class="form-section">
              <div class="section-header">
                <div class="section-num">3</div>
                <div class="section-title">Penerima</div>
              </div>
              <div class="field-grid">
                <div class="f-label full">
                  <span>Kepada (Yth.)</span>
                  <input name="recipient" placeholder="Yth. Kepala Bagian ..." value="<%= defaults.recipient %>" />
                </div>
                <div class="f-label full">
                  <span>Alamat Penerima <span style="font-weight:400;text-transform:none;letter-spacing:0">(opsional — bisa bold, list, dsb.)</span></span>
                  <div class="quill-wrap quill-wrap--sm">
                    <div id="recipientEditor"></div>
                  </div>
                  <textarea class="hidden-field" name="recipientAddress"     id="recipientAddress"><%= defaults.recipientAddress %></textarea>
                  <textarea class="hidden-field" name="recipientAddressHtml" id="recipientAddressHtml"><%= defaults.recipientAddressHtml||'' %></textarea>
                </div>
              </div>
            </div>
          </div>

          <!-- ④ Isi Surat -->
          <div class="form-card">
            <div class="form-section">
              <div class="section-header">
                <div class="section-num">4</div>
                <div class="section-title">Isi Surat</div>
              </div>
              <div class="quill-wrap quill-wrap--lg">
                <div id="bodyEditor"></div>
              </div>
              <textarea class="hidden-field" name="body"     id="body"><%= defaults.body %></textarea>
              <textarea class="hidden-field" name="bodyHtml" id="bodyHtml"><%= defaults.bodyHtml||'' %></textarea>
            </div>
          </div>

          <!-- ⑤ Penandatangan -->
          <div class="form-card">
            <div class="form-section">
              <div class="section-header">
                <div class="section-num">5</div>
                <div class="section-title">Penandatangan</div>
              </div>
              <div class="field-grid">
                <div class="f-label full">
                  <span>Salam / Hormat <span style="font-weight:400;text-transform:none;letter-spacing:0">(misal: Hormat kami,)</span></span>
                  <textarea name="closing" rows="3" placeholder="Hormat kami,"><%= defaults.closing||'Hormat kami,' %></textarea>
                </div>
                <div class="f-label">
                  <span>Nama Penandatangan</span>
                  <input name="signatoryName" value="<%= defaults.signatoryName %>" placeholder="Dr. Nama Lengkap, M.T." />
                </div>
                <div class="f-label">
                  <span>Jabatan</span>
                  <input name="signatoryTitle" value="<%= defaults.signatoryTitle %>" placeholder="Kepala Laboratorium" />
                </div>
                <div class="f-label">
                  <span>Ukuran Barcode (pt) <span style="font-weight:400;text-transform:none;letter-spacing:0">(opsional, default 92)</span></span>
                  <input type="number" name="barcodeSizePt" min="40" max="200" step="4" value="<%= defaults.barcodeSizePt||92 %>" />
                </div>
              </div>
            </div>
          </div>

          <!-- ⑥ Data Surat Tugas (conditional) -->
          <div id="taskExtras" style="display:none">
            <div class="form-card">
              <div class="form-section">
                <div class="section-header">
                  <div class="section-num">6</div>
                  <div class="section-title">Data Surat Tugas</div>
                </div>
                <div class="field-grid">
                  <div class="f-label">
                    <span>NIP Penandatangan <span style="font-weight:400;text-transform:none;letter-spacing:0">(opsional)</span></span>
                    <input name="signatoryNip" value="<%= defaults.signatoryNip||'' %>" placeholder="NIP. 123456789" />
                  </div>
                  <div class="f-label">
                    <span>Instansi <span style="font-weight:400;text-transform:none;letter-spacing:0">(opsional)</span></span>
                    <input name="signatoryInstansi" value="<%= defaults.signatoryInstansi||'' %>" placeholder="Universitas Telkom" />
                  </div>
                  <div class="f-label full">
                    <span>Paragraf penutup <span style="font-weight:400;text-transform:none;letter-spacing:0">(misal: Demikian kami sampaikan...)</span></span>
                    <textarea name="closingParagraph" rows="3" placeholder="Demikian kami sampaikan penugasan ini agar dapat digunakan sebagaimana mestinya."><%= defaults.closingParagraph||'' %></textarea>
                  </div>
                  <div class="f-label full">
                    <span>Teks sebelum tabel peserta</span>
                    <input name="tableIntroText" value="<%= defaults.tableIntroText||'Dengan ini memberikan tugas kepada:' %>" placeholder="Dengan ini memberikan tugas kepada:" />
                  </div>
                  <div class="f-label full">
                    <span>Teks sebelum detail acara <span style="font-weight:400;text-transform:none;letter-spacing:0">(kosongkan jika tidak ada detail)</span></span>
                    <input name="detailsIntroText" value="<%= defaults.detailsIntroText||'Yang akan diselenggarakan pada:' %>" placeholder="Yang akan diselenggarakan pada:" />
                  </div>
                  <div class="f-label full">
                    <span>Detail Acara <span style="font-weight:400;text-transform:none;letter-spacing:0">(Kunci: Nilai, satu per baris)</span></span>
                    <textarea name="detailsRaw" rows="5" placeholder="Hari, tanggal: Kamis, 8 Mei 2026&#10;Waktu: 09.00 WIB s.d selesai&#10;Tempat: Ruang Rapat ...&#10;Acara: Focus Group Discussion"><%= defaults.detailsRaw||'' %></textarea>
                  </div>
                  <div class="f-label full">
                    <span>Data Peserta / Tabel <span id="tableHint" style="font-weight:400;text-transform:none;letter-spacing:0"></span> <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--muted);font-size:11px">(nama kolom bisa diedit langsung)</span></span>
                    <div class="table-wrap">
                      <div class="table-toolbar">
                        <span>Klik <strong>+ Baris</strong> untuk menambah peserta</span>
                        <button class="btn ghost" type="button" id="addRowBtn" style="height:34px; padding:0 14px; font-size:13px">+ Baris</button>
                      </div>
                      <div style="overflow:auto">
                        <table id="tableEditor">
                          <thead id="tableHead"></thead>
                          <tbody id="tableBody"></tbody>
                        </table>
                      </div>
                    </div>
                    <textarea class="hidden-field" name="tableRowsRaw" id="tableRowsRaw"><%= defaults.tableRowsRaw||'' %></textarea>
                    <input class="hidden-field" type="text" name="tableColsRaw" id="tableColsRaw" value="<%= defaults.tableColsRaw||'' %>" />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit -->
          <div class="submit-bar">
            <span class="hint">Pastikan semua data sudah benar sebelum preview.</span>
            <button type="submit" class="btn">Preview Surat &rarr;</button>
          </div>

        </form>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
    <script>
    (function () {
      var TB_FULL = [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        [{ indent: '-1' }, { indent: '+1' }],
        [{ align: [] }],
        ['link', 'image'],
        ['blockquote'],
        ['clean']
      ];
      var TB_SIMPLE = [
        ['bold', 'italic', 'underline'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['link'],
        ['clean']
      ];

      var bodyQuill = new Quill('#bodyEditor', {
        theme: 'snow',
        placeholder: 'Tulis isi surat di sini…',
        modules: { toolbar: TB_FULL }
      });

      var recipientQuill = new Quill('#recipientEditor', {
        theme: 'snow',
        placeholder: 'Alamat penerima (opsional)…',
        modules: { toolbar: TB_SIMPLE }
      });

      var initBody      = <%- JSON.stringify(defaults.bodyHtml      || '') %>;
      var initRecipient = <%- JSON.stringify(defaults.recipientAddressHtml || '') %>;
      if (initBody)      bodyQuill.root.innerHTML      = initBody;
      if (initRecipient) recipientQuill.root.innerHTML = initRecipient;

      function syncAll() {
        document.getElementById('bodyHtml').value             = bodyQuill.root.innerHTML;
        document.getElementById('body').value                 = bodyQuill.getText().trim();
        document.getElementById('recipientAddressHtml').value = recipientQuill.root.innerHTML;
        document.getElementById('recipientAddress').value     = recipientQuill.getText().trim();
      }

      document.getElementById('letterForm').addEventListener('submit', function () { syncAll(); });

      /* Font preview */
      var fontStacks = {
        calibri:   'Calibri, "Segoe UI", Arial, sans-serif',
        arial:     'Arial, Helvetica, sans-serif',
        times:     '"Times New Roman", Times, serif',
        georgia:   'Georgia, "Times New Roman", serif',
        tahoma:    'Tahoma, "Segoe UI", Arial, sans-serif',
        verdana:   'Verdana, "Segoe UI", Arial, sans-serif',
        trebuchet: '"Trebuchet MS", "Segoe UI", Arial, sans-serif',
        garamond:  'Garamond, "Times New Roman", serif',
        courier:   '"Courier New", Courier, monospace',
        system:    'system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif',
      };
      var fontSelect = document.getElementById('fontSelect');
      var fontCustom = document.getElementById('fontCustom');
      function applyFont() {
        var stack = (fontCustom && fontCustom.value.trim()) || fontStacks[fontSelect.value] || fontStacks.calibri;
        document.documentElement.style.setProperty('--uiFont', stack);
      }
      if (fontSelect) fontSelect.addEventListener('change', applyFont);
      if (fontCustom) fontCustom.addEventListener('input', applyFont);
      applyFont();

      /* Template switcher */
      var templateSelect = document.getElementById('templateSelect');
      var taskExtras     = document.getElementById('taskExtras');

      function columnsForTemplate(t) {
        if (t === 'SURAT_TUGAS') return ['Nama', 'NIM'];
        if (t === 'SURAT_TUGAS_IN_HOUSE_TRAINING') return ['Nama', 'Fakultas'];
        return ['Nama', 'NIP', 'Fakultas'];
      }

      function esc(s) {
        return String(s||'').replace(/[&<>"']/g, function(c){
          return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
        });
      }

      function buildTable(t) {
        var head      = document.getElementById('tableHead');
        var body      = document.getElementById('tableBody');
        var raw       = document.getElementById('tableRowsRaw');
        var colsHidden = document.getElementById('tableColsRaw');
        var addBtn    = document.getElementById('addRowBtn');
        var hint      = document.getElementById('tableHint');
        if (!head || !body || !raw || !addBtn) return;

        var cols = columnsForTemplate(t);

        function serializeCols() {
          var names = [];
          Array.prototype.forEach.call(head.querySelectorAll('.col-hdr-inp'), function(inp) {
            names.push(inp.value.trim() || inp.getAttribute('data-default') || '');
          });
          cols = names;
          if (hint) hint.textContent = '— kolom: ' + cols.join(', ');
          if (colsHidden) colsHidden.value = cols.join('|');
        }

        function buildHeaders() {
          var ths = '<th style="width:44px;text-align:center">No</th>';
          cols.forEach(function(c) {
            ths += '<th style="padding:4px 6px">'
              + '<input class="col-hdr-inp" data-default="' + esc(c) + '" value="' + esc(c) + '" '
              + 'title="Klik untuk mengedit nama kolom" '
              + 'style="border:none;background:transparent;font-size:12px;font-weight:700;text-transform:uppercase;'
              + 'letter-spacing:0.4px;color:var(--muted);width:100%;min-width:60px;padding:2px 4px;'
              + 'border-radius:4px;cursor:text;outline:none;" '
              + 'onfocus="this.style.background=\'rgba(11,122,141,0.06)\';this.style.color=\'var(--primary)\'" '
              + 'onblur="this.style.background=\'transparent\';this.style.color=\'var(--muted)\'" />'
              + '</th>';
          });
          ths += '<th style="width:80px"></th>';
          head.innerHTML = '<tr>' + ths + '</tr>';
          Array.prototype.forEach.call(head.querySelectorAll('.col-hdr-inp'), function(inp) {
            inp.addEventListener('input', serializeCols);
          });
          if (hint) hint.textContent = '— kolom: ' + cols.join(', ');
          if (colsHidden) colsHidden.value = cols.join('|');
        }

        buildHeaders();

        function serialize() {
          var lines = [];
          Array.prototype.forEach.call(body.querySelectorAll('tr'), function(tr) {
            var parts = [];
            Array.prototype.forEach.call(tr.querySelectorAll('input[data-colidx]'), function(inp) {
              parts.push(inp.value.trim());
            });
            if (parts.some(function(p) { return p; })) lines.push(parts.join('|'));
          });
          raw.value = lines.join('\n');
        }

        function renumber() {
          Array.prototype.forEach.call(body.querySelectorAll('[data-no]'), function(el, i) {
            el.textContent = i + 1;
          });
        }

        function addRow(vals) {
          vals = Array.isArray(vals) ? vals : [];
          var tds = '<td data-no style="text-align:center;padding:6px 8px;color:var(--muted);font-size:13px"></td>';
          cols.forEach(function(c, i) {
            tds += '<td style="padding:4px 6px">'
              + '<input data-colidx="' + i + '" value="' + esc(vals[i]||'') + '" />'
              + '</td>';
          });
          tds += '<td style="padding:4px 8px">'
            + '<button class="btn ghost" type="button" data-del style="height:30px;padding:0 10px;font-size:12px">Hapus</button>'
            + '</td>';
          var tr = document.createElement('tr');
          tr.innerHTML = tds;
          tr.addEventListener('input', serialize);
          tr.querySelector('[data-del]').addEventListener('click', function() {
            tr.remove(); renumber(); serialize();
          });
          body.appendChild(tr);
          renumber();
          serialize();
        }

        body.innerHTML = '';
        var existing = String(raw.value||'').trim();
        if (existing) {
          existing.split(/\r?\n/).forEach(function(line) {
            var parts = line.split('|').map(function(p) { return p.trim(); });
            if (parts.some(Boolean)) addRow(parts.slice(0, cols.length));
          });
        } else {
          addRow([]);
        }

        addBtn.onclick = function() { addRow([]); };
      }

      function applyTemplate() {
        if (!templateSelect || !taskExtras) return;
        var t = String(templateSelect.value||'DEFAULT').toUpperCase();
        var isTask = t !== 'DEFAULT';
        taskExtras.style.display = isTask ? 'block' : 'none';
        if (isTask) buildTable(t);
      }

      if (templateSelect) templateSelect.addEventListener('change', applyTemplate);
      applyTemplate();
    })();
    </script>
  </body>
</html>
