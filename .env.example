# Do NOT commit your real secrets (.env is gitignored)

# MongoDB connection string (non-SRV recommended)
MONGODB_URI=

# Express session secret
SESSION_SECRET=

# Secret for signing barcode/QR tokens (HMAC)
SIGNATURE_SECRET=

# Public base URL used to generate verification links inside QR (optional in dev)
# Example: http://localhost:3000
BASE_URL=http://localhost:3000

# One-time seed for initial superadmin (run: npm run seed:superadmin)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin

# SMTP settings for OTP email (optional in dev; if empty, OTP will be logged to console only)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AILO Web Mailer" <no-reply@example.com>

# Optional: preferred OTP channel (email or whatsapp)
OTP_CHANNEL=email

# Optional: WhatsApp webhook/API config (implementation placeholder)
WHATSAPP_WEBHOOK_URL=
WHATSAPP_API_TOKEN=
